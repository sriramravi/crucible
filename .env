# Copy this file to .env and fill in values before running docker-compose

# Backend
SECRET_KEY=change-me-to-a-random-32-char-string

# Gitea
GITEA_ADMIN_TOKEN=your-gitea-admin-token
GITEA_ADMIN_USER=gitea_admin

# Gitea Act Runner token (obtained from Gitea UI after setup)
ACT_RUNNER_TOKEN=your-act-runner-registration-token

# Jenkins (defaults work for local dev)
# JENKINS_ADMIN_USER=admin
# JENKINS_ADMIN_PASSWORD=admin

# Nexus (defaults work for local dev)
# NEXUS_ADMIN_USER=admin
# NEXUS_ADMIN_PASSWORD=admin123
